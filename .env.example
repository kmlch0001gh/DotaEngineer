# ── API Keys ──────────────────────────────────────────────────────────────────
OPENDOTA_API_KEY=           # https://www.opendota.com/api-keys
STRATZ_API_TOKEN=           # https://stratz.com/api
STEAM_API_KEY=              # https://steamcommunity.com/dev/apikey

# ── Player config ─────────────────────────────────────────────────────────────
# Your Steam account ID (32-bit, not 64-bit)
MY_STEAM_ID=

# MMR bracket for filtering (fetch matches only above this MMR)
HIGH_MMR_THRESHOLD=7000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://dota:dota@localhost:5432/dotaengineer
DUCKDB_PATH=./data/warehouse.duckdb

# ── Prefect ───────────────────────────────────────────────────────────────────
PREFECT_API_URL=http://localhost:4200/api

# ── Storage ───────────────────────────────────────────────────────────────────
RAW_DATA_PATH=./data/raw
PROCESSED_DATA_PATH=./data/processed
